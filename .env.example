# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit `.env` — it goes in .gitignore for a reason.

# ─── Database ──────────────────────────────────────────────────────────────
# Get a free Postgres URL from neon.tech or supabase.com
DATABASE_URL="postgresql://user:password@host:5432/estatehub?sslmode=require"

# ─── Auth (Clerk — recommended for Phase 0) ────────────────────────────────
# Get free keys from clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# ─── Storage (later phases) ────────────────────────────────────────────────
# S3 or any S3-compatible bucket for property photos
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION="ap-south-1"

# ─── Maps (later phases) ───────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Payments (later phases) ───────────────────────────────────────────────
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""

# ─── Communications (later phases) ─────────────────────────────────────────
# MSG91_AUTH_KEY=""

# ─── App-level ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
